# ─────────────────────────────────────
# Supabase
# ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─────────────────────────────────────
# Site
# ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────
# AI Providers
# ─────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────
# SEO Tools
# ─────────────────────────────────────
COPYLEAKS_API_KEY=
DATAFORSEO_API_KEY=
DATAFORSEO_API_SECRET=

# ─────────────────────────────────────
# Email — Resend (https://resend.com)
# ─────────────────────────────────────
# Leave empty to use local-only mode.
# When configured, emails will be sent via Resend API.
# When empty, the system shows: "Email provider not configured"
RESEND_API_KEY=

# ─────────────────────────────────────
# Email — SMTP (alternative to Resend)
# ─────────────────────────────────────
# Leave empty to use local-only mode.
# When configured, emails will be sent via nodemailer + SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nextill.ai
